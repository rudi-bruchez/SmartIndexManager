<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartIndexManager.App.ViewModels"
             xmlns:loc="clr-namespace:SmartIndexManager.App.Localization"
             x:Class="SmartIndexManager.App.Views.ConnectionManagerView"
             x:DataType="vm:ConnectionManagerViewModel">
    <StackPanel Orientation="Horizontal" Spacing="8">
        <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding Selected}"
                  DisplayMemberBinding="{Binding Name}" MinWidth="180" />
        <TextBox Watermark="{x:Static loc:Strings.Connection_DatabasesWatermark}"
                  Text="{Binding DatabasesText}" MinWidth="240" />
        <Button Content="{x:Static loc:Strings.Action_Add}" Command="{Binding AddCommand}" />
        <Button Content="{x:Static loc:Strings.Action_Save}" Command="{Binding SaveCommand}" />
        <Button Content="{x:Static loc:Strings.Action_Connect}" Command="{Binding ConnectCommand}" />
    </StackPanel>
</UserControl>
