<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartIndexManager.App.ViewModels"
             xmlns:loc="clr-namespace:SmartIndexManager.App.Localization"
             x:Class="SmartIndexManager.App.Views.IndexGridView"
             x:DataType="vm:IndexGridViewModel">
    <DockPanel>
        <TextBox DockPanel.Dock="Top" Watermark="{x:Static loc:Strings.Grid_Filter}"
                 Text="{Binding FilterText}" Margin="4" />
        <DataGrid ItemsSource="{Binding View}" SelectedItem="{Binding SelectedRow}"
                  IsReadOnly="True" CanUserSortColumns="True" CanUserReorderColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static loc:Strings.Grid_Column_Database}" Binding="{Binding Database}" />
                <DataGridTextColumn Header="{x:Static loc:Strings.Grid_Column_Schema}"   Binding="{Binding Schema}" />
                <DataGridTextColumn Header="{x:Static loc:Strings.Grid_Column_Table}"    Binding="{Binding Table}" />
                <DataGridTextColumn Header="{x:Static loc:Strings.Grid_Column_Index}"    Binding="{Binding Name}" />
                <DataGridTextColumn Header="{x:Static loc:Strings.Grid_Column_Type}"     Binding="{Binding Type}" />
                <DataGridTextColumn Header="{x:Static loc:Strings.Grid_Column_Key}"      Binding="{Binding KeySummary}" />
                <DataGridTextColumn Header="{x:Static loc:Strings.Grid_Column_Includes}" Binding="{Binding IncludeSummary}" />
                <DataGridTextColumn Header="{x:Static loc:Strings.Grid_Column_SizeMb}"   Binding="{Binding SizeMb}" />
                <DataGridTextColumn Header="{x:Static loc:Strings.Grid_Column_Seeks}"    Binding="{Binding Seeks}" />
                <DataGridTextColumn Header="{x:Static loc:Strings.Grid_Column_Scans}"    Binding="{Binding Scans}" />
                <DataGridTextColumn Header="{x:Static loc:Strings.Grid_Column_Updates}"  Binding="{Binding Updates}" />
                <DataGridTextColumn Header="{x:Static loc:Strings.Grid_Column_Score}"    Binding="{Binding Score}" />
                <DataGridTemplateColumn Header="">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <Border Background="#C0392B" CornerRadius="3" Padding="4,1"
                                        IsVisible="{Binding NotDeletable}" ToolTip.Tip="{Binding NotDeletableReason}">
                                    <TextBlock Text="{x:Static loc:Strings.Badge_NotDeletable}" Foreground="White" FontSize="11" />
                                </Border>
                                <Border Background="#B5651D" CornerRadius="3" Padding="4,1" IsVisible="{Binding Redundant}">
                                    <TextBlock Text="{x:Static loc:Strings.Badge_Redundant}" Foreground="White" FontSize="11" />
                                </Border>
                                <Border Background="#2E86C1" CornerRadius="3" Padding="4,1" IsVisible="{Binding SupportsForeignKey}">
                                    <TextBlock Text="{x:Static loc:Strings.Badge_ForeignKey}" Foreground="White" FontSize="11" />
                                </Border>
                                <Border Background="#7D3C98" CornerRadius="3" Padding="4,1" IsVisible="{Binding ReferencedByHint}">
                                    <TextBlock Text="{x:Static loc:Strings.Badge_Hint}" Foreground="White" FontSize="11" />
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
